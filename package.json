{
  "name": "senex",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vinext dev",
    "build": "vinext build",
    "start": "vinext start",
    "preview": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:preview": "wrangler versions upload",
    "deploy:prod": "pnpm run check:migrations && bash scripts/deploy-prod.sh",
    "migrate:prod": "wrangler d1 migrations apply senex-db --remote",
    "check:migrations": "bash scripts/check-migrations-safe.sh",
    "typecheck": "vinext typegen && tsc --noEmit",
    "test": "vitest run",
    "test:browser": "pnpm db:local:migrate && playwright test",
    "test:watch": "vitest",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "smoke:deploy": "node scripts/smoke-deploy.mjs",
    "db:local:migrate": "wrangler d1 migrations apply DB --local",
    "db:remote:migrate": "wrangler d1 migrations apply senex-db --remote",
    "cf:whoami": "wrangler whoami",
    "cf:typegen": "wrangler types",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "better-auth": "^1.6.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "kysely-d1": "^0.4.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "shadcn": "^4.10.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "use-sync-external-store": "^1.6.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@cloudflare/vite-plugin": "^1.40.0",
    "@cloudflare/vitest-pool-workers": "^0.16.13",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitejs/plugin-rsc": "^0.5.27",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "react-server-dom-webpack": "^19.2.7",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vinext": "^0.0.55",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "wrangler": "^4.98.0"
  },
  "packageManager": "pnpm@10.31.0+sha512.e3927388bfaa8078ceb79b748ffc1e8274e84d75163e67bc22e06c0d3aed43dd153151cbf11d7f8301ff4acb98c68bdc5cadf6989532801ffafe3b3e4a63c268",
  "type": "module",
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,md,json,yml,yaml}": [
      "prettier --write"
    ]
  },
  "//": "AIDEV-NOTE: kysely is pinned to 0.28.x — better-auth's prebuilt D1/sqlite dialect chunks and kysely-d1 import DEFAULT_MIGRATION_LOCK_TABLE, which kysely 0.29 removed. Lift the pin once better-auth ships dists built against 0.29."
}
