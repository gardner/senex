# Local development environment variables for the vinext CLI (build/dev).
#
# Set up local development with:
#
#   cp .env.example .env
#   cp .dev.vars.example .dev.vars
#
# .env feeds the vinext CLI (Next.js-style env loading).
# .dev.vars feeds the Cloudflare Workers runtime in `pnpm dev` — that is
# where the app actually reads auth secrets from (via `env` bindings).
# Keep the two files in sync. See docs/environment-variables.md for details.
#
# Everything in THIS example file is safe to commit. Never commit the real
# .env or .dev.vars files — they are gitignored.

# Secret used by Better Auth to sign sessions and tokens.
# The value below is fine for LOCAL development only.
# Production uses a real 32+ character secret stored in Cloudflare.
BETTER_AUTH_SECRET=Not_Really_A_Secret_for_dev_env

# The URL the app runs at. Locally this is the dev server.
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth sign-in (optional locally — email/password works without it).
# The client ID is public and safe to commit; the client secret is NOT.
GOOGLE_CLIENT_ID=<your-google-oauth-client-id>
GOOGLE_CLIENT_SECRET=<your-google-oauth-client-secret>

# Which environment this is: development | preview | production
APP_ENV=development
